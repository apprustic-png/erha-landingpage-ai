{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "public/**",
          "admin/**",
          "images/**",
          "index.html",
          "styles.css",
          "scanner.css",
          "script.js"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server.js" },
    { "src": "/admin/(.*)", "dest": "server.js" },
    { "src": "/admin", "dest": "server.js" },
    { "src": "/(.*)", "dest": "server.js" }
  ]
}
